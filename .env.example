# StepFun (default provider). Required for real synthesis with --provider stepfun.
STEPFUN_API_KEY=
# Optional: override the StepFun API base URL (default https://api.stepfun.ai/v1).
# STEPFUN_BASE_URL=

# OpenRouter (Kokoro-82M). Required for real synthesis with --provider openrouter.
OPENROUTER_API_KEY=
# Optional: override the OpenRouter API base URL (default https://openrouter.ai/api/v1).
# OPENROUTER_BASE_URL=
