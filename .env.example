# StepFun (default provider). Required for real synthesis with --provider stepfun.
STEPFUN_API_KEY=
# Optional: fallback key name, checked only if STEPFUN_API_KEY is unset.
# STEPFUN_STEP_PLAN_API_KEY=
# Optional: override the StepFun API base URL (default https://api.stepfun.ai/v1).
# STEPFUN_BASE_URL=

# OpenRouter (Kokoro-82M). Required for real synthesis with --provider openrouter,
# and for the automatic StepFun->OpenRouter/Kokoro fallback on a quota outage
# (read only when the fallback fires; opt out with --fallback-model none).
OPENROUTER_API_KEY=
# Optional: override the OpenRouter API base URL (default https://openrouter.ai/api/v1).
# OPENROUTER_BASE_URL=

# Local Kokoro server (--provider local). Both are OPTIONAL: local servers are
# usually unauthenticated (a placeholder key is used if none is set), and the
# base URL defaults to Kokoro-FastAPI's convention. Set the base URL to point at
# a non-default host/port, and the key only if you front the server with an
# authenticating proxy. See server/README.md (added by the local-server slice).
# LOCAL_TTS_BASE_URL=http://127.0.0.1:8880/v1
# LOCAL_TTS_API_KEY=
